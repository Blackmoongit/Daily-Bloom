@page "/dashboard/books"
@attribute [Authorize]
@inject AppDbContext Db
@inject CurrentUserService CurrentUser
@inject IWebHostEnvironment Env
@using Microsoft.EntityFrameworkCore

<h1>📚 Books</h1>

<div class="toolbar">
    <button class="btn-primary small" @onclick="OpenNewBook">+ Add Book</button>
</div>

<div class="books-columns">
    <div class="books-col">
        <h3>🌙 Will Read</h3>
        <div class="book-grid">
            @foreach (var b in _willRead)
            {
                <div class="book-card">
                    <input type="checkbox" class="book-check" title="Mark as read"
                           @onchange="e => ToggleRead(b, e)" />
                    @if (!string.IsNullOrEmpty(b.CoverPath))
                    {
                        <img src="@b.CoverPath" class="book-cover" alt="@b.Name" />
                    }
                    else
                    {
                        <div class="book-cover placeholder">📖</div>
                    }
                    <div class="book-name">@b.Name</div>
                    <div class="book-actions">
                        <button class="icon-btn" @onclick="() => EditBook(b)">✏️</button>
                        <button class="icon-btn" @onclick="() => DeleteBook(b)">🗑️</button>
                    </div>
                </div>
            }
            @if (!_willRead.Any()) { <p class="empty-state-sm">Your reading list is empty 🌱</p> }
        </div>
    </div>

    <div class="books-col">
        <h3>✨ Read</h3>
        <div class="book-grid">
            @foreach (var b in _read)
            {
                <div class="book-card">
                    <input type="checkbox" checked title="Read" @onchange="e => ToggleRead(b, e)" />
                    @if (!string.IsNullOrEmpty(b.CoverPath))
                    {
                        <img src="@b.CoverPath" class="book-cover" alt="@b.Name" />
                    }
                    else
                    {
                        <div class="book-cover placeholder">📖</div>
                    }
                    <div class="book-name">@b.Name</div>
                    <div class="book-rating">@Stars(b.Rating)</div>
                    @if (!string.IsNullOrWhiteSpace(b.Reflection))
                    {
                        <p class="book-reflection">"@b.Reflection"</p>
                    }
                    <div class="book-actions">
                        <button class="icon-btn" @onclick="() => EditBook(b)">✏️</button>
                        <button class="icon-btn" @onclick="() => DeleteBook(b)">🗑️</button>
                    </div>
                </div>
            }
            @if (!_read.Any()) { <p class="empty-state-sm">No finished books yet — keep going! 📗</p> }
        </div>
    </div>
</div>

@if (_showEditor)
{
    <div class="modal-backdrop" @onclick="CloseEditor">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2>@(_editing!.Id == 0 ? "New Book" : "Edit Book")</h2>

            <label>Book Name</label>
            <input class="input" @bind="_editing.Name" />

            <label>Cover (optional)</label>
            <InputFile OnChange="HandleCover" class="input" accept=".png,.jpg,.jpeg,.webp" />
            @if (!string.IsNullOrEmpty(_editing.CoverPath))
            {
                <img src="@_editing.CoverPath" class="avatar-preview" />
            }

            <label>Rating (0–5)</label>
            <input type="number" min="0" max="5" class="input" @bind="_editing.Rating" />

            <label>Comment / Reflection</label>
            <textarea class="input" rows="3" @bind="_editing.Reflection"></textarea>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseEditor">Cancel</button>
                <button class="btn-primary" @onclick="SaveBook">Save 🌸</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Book> _allBooks = new();
    private List<Book> _willRead = new();
    private List<Book> _read = new();
    private bool _showEditor;
    private Book? _editing;

    protected override async Task OnInitializedAsync() => await LoadBooks();

    private async Task LoadBooks()
    {
        var userId = CurrentUser.CurrentUserId!.Value;
        _allBooks = await Db.Books.Where(b => b.UserId == userId).OrderByDescending(b => b.AddedDate).ToListAsync();
        _willRead = _allBooks.Where(b => !b.IsRead).ToList();
        _read = _allBooks.Where(b => b.IsRead).ToList();
    }

    private void OpenNewBook()
    {
        _editing = new Book { UserId = CurrentUser.CurrentUserId!.Value };
        _showEditor = true;
    }

    private void EditBook(Book b) { _editing = b; _showEditor = true; }
    private void CloseEditor() { _showEditor = false; _editing = null; }

    private async Task SaveBook()
    {
        if (string.IsNullOrWhiteSpace(_editing!.Name)) return;
        if (_editing.Id == 0) Db.Books.Add(_editing);
        else Db.Books.Update(_editing);
        await Db.SaveChangesAsync();
        CloseEditor();
        await LoadBooks();
    }

    private async Task DeleteBook(Book b)
    {
        Db.Books.Remove(b);
        await Db.SaveChangesAsync();
        await LoadBooks();
    }

    private async Task ToggleRead(Book b, ChangeEventArgs e)
    {
        b.IsRead = (bool)(e.Value ?? false);
        await Db.SaveChangesAsync();
        await LoadBooks();
    }

    private async Task HandleCover(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var folder = Path.Combine(Env.WebRootPath, "uploads", "covers");
        Directory.CreateDirectory(folder);
        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var fullPath = Path.Combine(folder, fileName);

        await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        await using var fs = new FileStream(fullPath, FileMode.Create);
        await stream.CopyToAsync(fs);

        _editing!.CoverPath = $"/uploads/covers/{fileName}";
    }

    private string Stars(int rating) => string.Concat(Enumerable.Repeat("⭐", rating));
}
