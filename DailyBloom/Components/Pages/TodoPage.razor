@page "/dashboard/todo"
@attribute [Authorize]
@inject AppDbContext Db
@inject CurrentUserService CurrentUser
@inject IWebHostEnvironment Env
@using Microsoft.EntityFrameworkCore

<h1>✅ To-Do List</h1>

<div class="todo-layout">
    <!-- Main task panel -->
    <div class="todo-main">
        <div class="toolbar">
            <input class="input search-box" placeholder="🔍 Search tasks..." @bind-value="_search" @bind-value:event="oninput" @onkeyup="ApplyFilters" />

            <select class="input small" @bind="_viewMode" @bind:after="ApplyFilters">
                <option value="Day">Today</option>
                <option value="Week">This Week</option>
                <option value="Month">This Month</option>
                <option value="Year">This Year</option>
                <option value="All">All Tasks</option>
            </select>

            <button class="btn-primary small" @onclick="OpenNewTask">+ Add Task</button>
        </div>

        @if (!_filteredTasks.Any())
        {
            <p class="empty-state">No tasks here yet — add one to get blooming! 🌷</p>
        }

        @foreach (var task in _filteredTasks)
        {
            <div class="task-card priority-@task.Priority.ToString().ToLower()">
                <div class="task-card-header">
                    <input type="checkbox" checked="@task.IsCompleted" @onchange="e => ToggleComplete(task, e)" />
                    <span class="task-title @(task.IsCompleted ? "done" : "")">@task.Title</span>
                    <span class="badge">@task.Priority</span>
                    <span class="due-date">📅 @task.EndDate.ToString("MMM dd, yyyy")</span>
                    <button class="icon-btn" @onclick="() => EditTask(task)">✏️</button>
                    <button class="icon-btn" @onclick="() => DeleteTask(task)">🗑️</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(task.Description))
                {
                    <p class="task-desc">@task.Description</p>
                }
                @if (!string.IsNullOrWhiteSpace(task.Hashtags))
                {
                    <div class="hashtags">
                        @foreach (var tag in task.Hashtags.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="hashtag">@tag</span>
                        }
                    </div>
                }
                @if (task.SubTasks.Any())
                {
                    <ul class="subtask-list">
                        @foreach (var sub in task.SubTasks)
                        {
                            <li>
                                <input type="checkbox" checked="@sub.IsCompleted" @onchange="e => ToggleSubtask(sub, e)" />
                                <span class="@(sub.IsCompleted ? "done" : "")">@sub.Title</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </div>

    <!-- Calendar sidebar -->
    <div class="todo-calendar">
        <h3>📆 Upcoming Deadlines</h3>
        @foreach (var group in _filteredTasks.GroupBy(t => t.EndDate.Date).OrderBy(g => g.Key))
        {
            <div class="calendar-day">
                <div class="calendar-date">@group.Key.ToString("ddd, MMM dd")</div>
                @foreach (var t in group)
                {
                    <div class="calendar-task priority-@t.Priority.ToString().ToLower()">@t.Title</div>
                }
            </div>
        }
        @if (!_filteredTasks.Any())
        {
            <p class="empty-state-sm">Nothing scheduled 🌿</p>
        }
    </div>
</div>

@if (_showEditor)
{
    <div class="modal-backdrop" @onclick="CloseEditor">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2>@(_editingTask!.Id == 0 ? "New Task" : "Edit Task")</h2>

            <label>Title</label>
            <input class="input" @bind="_editingTask.Title" />

            <label>Description</label>
            <textarea class="input" rows="2" @bind="_editingTask.Description"></textarea>

            <div class="form-row">
                <div>
                    <label>Priority</label>
                    <select class="input" @bind="_editingTask.Priority">
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div>
                    <label>End Date</label>
                    <input type="date" class="input" value="@_editingTask.EndDate.ToString("yyyy-MM-dd")"
                           @onchange="e => _editingTask.EndDate = DateTime.Parse(e.Value!.ToString()!)" />
                </div>
            </div>

            <label>Hashtags (comma separated)</label>
            <input class="input" @bind="_editingTask.Hashtags" placeholder="#work, #urgent" />

            <label>Sub-tasks</label>
            @foreach (var sub in _editingTask.SubTasks)
            {
                <div class="sub-edit-row">
                    <input class="input" @bind="sub.Title" />
                    <button class="icon-btn" @onclick="() => _editingTask.SubTasks.Remove(sub)">✖</button>
                </div>
            }
            <button class="btn-secondary small" @onclick="() => _editingTask.SubTasks.Add(new SubTask())">+ Add sub-task</button>

            <label>Comments</label>
            @foreach (var c in _editingTask.Comments)
            {
                <p class="comment-line">💬 @c.Text <span class="comment-date">(@c.CreatedDate.ToString("MMM dd"))</span></p>
            }
            <div class="form-row">
                <input class="input" placeholder="Add a comment..." @bind="_newComment" />
                <button class="btn-secondary small" @onclick="AddComment">Add</button>
            </div>

            <label>Attachments</label>
            @foreach (var att in _editingTask.Attachments)
            {
                <p><a href="@att.FilePath" target="_blank">📎 @att.FileName</a></p>
            }
            <InputFile OnChange="HandleAttachment" class="input" />

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseEditor">Cancel</button>
                <button class="btn-primary" @onclick="SaveTask">Save 🌸</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Models.TaskItem> _allTasks = new();
    private List<Models.TaskItem> _filteredTasks = new();
    private string _search = "";
    private string _viewMode = "All";
    private bool _showEditor;
    private Models.TaskItem? _editingTask;
    private string _newComment = "";

    protected override async Task OnInitializedAsync() => await LoadTasks();

    private async Task LoadTasks()
    {
        var userId = CurrentUser.CurrentUserId!.Value;
        _allTasks = await Db.Tasks
            .Include(t => t.SubTasks)
            .Include(t => t.Comments)
            .Include(t => t.Attachments)
            .Where(t => t.UserId == userId)
            .OrderBy(t => t.EndDate)
            .ToListAsync();
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var now = DateTime.Today;
        IEnumerable<Models.TaskItem> q = _allTasks;

        q = _viewMode switch
        {
            "Day" => q.Where(t => t.EndDate.Date == now),
            "Week" => q.Where(t => t.EndDate.Date >= now && t.EndDate.Date <= now.AddDays(7)),
            "Month" => q.Where(t => t.EndDate.Year == now.Year && t.EndDate.Month == now.Month),
            "Year" => q.Where(t => t.EndDate.Year == now.Year),
            _ => q
        };

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.ToLower();
            q = q.Where(t => t.Title.ToLower().Contains(s)
                || (t.Description ?? "").ToLower().Contains(s)
                || (t.Hashtags ?? "").ToLower().Contains(s));
        }

        _filteredTasks = q.ToList();
        StateHasChanged();
    }

    private void OpenNewTask()
    {
        _editingTask = new Models.TaskItem { UserId = CurrentUser.CurrentUserId!.Value };
        _showEditor = true;
    }

    private void EditTask(Models.TaskItem task)
    {
        _editingTask = task;
        _showEditor = true;
    }

    private void CloseEditor()
    {
        _showEditor = false;
        _editingTask = null;
        _newComment = "";
    }

    private async Task SaveTask()
    {
        if (string.IsNullOrWhiteSpace(_editingTask!.Title)) return;

        if (_editingTask.Id == 0)
            Db.Tasks.Add(_editingTask);
        else
            Db.Tasks.Update(_editingTask);

        await Db.SaveChangesAsync();
        CloseEditor();
        await LoadTasks();
    }

    private async Task DeleteTask(Models.TaskItem task)
    {
        Db.Tasks.Remove(task);
        await Db.SaveChangesAsync();
        await LoadTasks();
    }

    private async Task ToggleComplete(Models.TaskItem task, ChangeEventArgs e)
    {
        task.IsCompleted = (bool)(e.Value ?? false);
        await Db.SaveChangesAsync();
    }

    private async Task ToggleSubtask(SubTask sub, ChangeEventArgs e)
    {
        sub.IsCompleted = (bool)(e.Value ?? false);
        await Db.SaveChangesAsync();
    }

    private void AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        _editingTask!.Comments.Add(new TaskComment { Text = _newComment, CreatedDate = DateTime.Now });
        _newComment = "";
    }

    private async Task HandleAttachment(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var folder = Path.Combine(Env.WebRootPath, "uploads", "tasks");
        Directory.CreateDirectory(folder);
        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var fullPath = Path.Combine(folder, fileName);

        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        await using var fs = new FileStream(fullPath, FileMode.Create);
        await stream.CopyToAsync(fs);

        _editingTask!.Attachments.Add(new TaskAttachment { FileName = file.Name, FilePath = $"/uploads/tasks/{fileName}" });
    }
}
