@page "/register"
@inject AuthService AuthSvc
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IWebHostEnvironment Env

<div class="auth-wrap">
    <div class="auth-card">
        <h1>🌱 Join Daily Bloom</h1>
        <p class="subtitle">Set up your cozy little corner of productivity.</p>

        <EditForm Model="_form" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <label>Full Name</label>
            <InputText @bind-Value="_form.Name" class="input" placeholder="Jane Doe" />

            <label>Username</label>
            <InputText @bind-Value="_form.Username" class="input" placeholder="janedoe" />

            <label>Password</label>
            <InputText @bind-Value="_form.Password" type="password" class="input" placeholder="••••••••" />

            <label>Date of Birth</label>
            <InputDate @bind-Value="_form.DateOfBirth" class="input" />

            <label>Profile Picture (optional)</label>
            <InputFile OnChange="HandleFileSelected" class="input" accept=".png,.jpg,.jpeg,.webp" />
            @if (_previewPath != null)
            {
                <img src="@_previewPath" class="avatar-preview" alt="preview" />
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="error-text">@_error</p>
            }

            <button type="submit" class="btn-primary">Create account 🌸</button>
        </EditForm>

        <p class="switch-link">Already have an account? <a href="login">Log in</a></p>
    </div>
</div>

@code {
    private RegisterForm _form = new();
    private string? _error;
    private string? _previewPath;
    private string? _savedRelativePath;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var uploadsFolder = Path.Combine(Env.WebRootPath, "uploads", "profiles");
        Directory.CreateDirectory(uploadsFolder);
        var fullPath = Path.Combine(uploadsFolder, fileName);

        await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB max
        await using var fs = new FileStream(fullPath, FileMode.Create);
        await stream.CopyToAsync(fs);

        _savedRelativePath = $"/uploads/profiles/{fileName}";
        _previewPath = _savedRelativePath;
    }

    private async Task HandleRegister()
    {
        var (success, message, user) = await AuthSvc.RegisterAsync(
            _form.Name, _form.Username, _form.Password, _form.DateOfBirth, _savedRelativePath);

        if (!success || user == null)
        {
            _error = message;
            return;
        }

        await CurrentUser.SignInAsync(user.Id, user.Name);
        Nav.NavigateTo("/dashboard/todo", true);
    }

    public class RegisterForm
    {
        public string Name { get; set; } = "";
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public DateTime DateOfBirth { get; set; } = DateTime.Today.AddYears(-20);
    }
}
