@page "/dashboard/budget"
@attribute [Authorize]
@inject AppDbContext Db
@inject CurrentUserService CurrentUser
@using Microsoft.EntityFrameworkCore

<h1>💰 Budgeting</h1>

<div class="toolbar">
    <select class="input small" @bind="_selectedMonth" @bind:after="ApplyMonthFilter">
        @foreach (var m in _availableMonths)
        {
            <option value="@m.ToString("yyyy-MM")">@m.ToString("MMMM yyyy")</option>
        }
    </select>
    <button class="btn-primary small" @onclick="() => OpenEditor(true)">+ Add Income</button>
    <button class="btn-secondary small" @onclick="() => OpenEditor(false)">+ Add Expense</button>
</div>

<div class="budget-summary">
    <div class="summary-card income">
        <span>Total Income</span>
        <strong>$@_monthIncomeTotal.ToString("N2")</strong>
    </div>
    <div class="summary-card expense">
        <span>Total Expense</span>
        <strong>$@_monthExpenseTotal.ToString("N2")</strong>
    </div>
    <div class="summary-card grand @(_grandTotal >= 0 ? "positive" : "negative")">
        <span>Grand Total</span>
        <strong>$@_grandTotal.ToString("N2")</strong>
    </div>
</div>

<div class="budget-columns">
    <div class="budget-col">
        <h3>📈 Income</h3>
        @foreach (var i in _monthIncomes)
        {
            <div class="budget-row">
                <div>
                    <strong>@i.Description</strong>
                    <div class="budget-meta">@i.Date.ToString("MMM dd") — @i.Comments</div>
                </div>
                <div class="budget-amount income-text">+$@i.Amount.ToString("N2")</div>
                <button class="icon-btn" @onclick="() => EditIncome(i)">✏️</button>
                <button class="icon-btn" @onclick="() => DeleteIncome(i)">🗑️</button>
            </div>
        }
        @if (!_monthIncomes.Any()) { <p class="empty-state-sm">No income logged this month.</p> }
    </div>

    <div class="budget-col">
        <h3>📉 Expenses</h3>
        @foreach (var x in _monthExpenses)
        {
            <div class="budget-row">
                <div>
                    <strong>@x.Description</strong>
                    <div class="budget-meta">@x.Date.ToString("MMM dd") — @x.Comments</div>
                </div>
                <div class="budget-amount expense-text">-$@x.Amount.ToString("N2")</div>
                <button class="icon-btn" @onclick="() => EditExpense(x)">✏️</button>
                <button class="icon-btn" @onclick="() => DeleteExpense(x)">🗑️</button>
            </div>
        }
        @if (!_monthExpenses.Any()) { <p class="empty-state-sm">No expenses logged this month.</p> }
    </div>
</div>

@if (_showEditor)
{
    <div class="modal-backdrop" @onclick="CloseEditor">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2>@(_isIncomeMode ? (_editIncome!.Id == 0 ? "New Income" : "Edit Income") : (_editExpense!.Id == 0 ? "New Expense" : "Edit Expense"))</h2>

            @if (_isIncomeMode)
            {
                <label>Date</label>
                <input type="date" class="input" value="@_editIncome!.Date.ToString("yyyy-MM-dd")" @onchange="e => _editIncome.Date = DateTime.Parse(e.Value!.ToString()!)" />
                <label>Description</label>
                <input class="input" @bind="_editIncome.Description" />
                <label>Amount</label>
                <input type="number" step="0.01" class="input" @bind="_editIncome.Amount" />
                <label>Comments</label>
                <textarea class="input" @bind="_editIncome.Comments"></textarea>
            }
            else
            {
                <label>Date</label>
                <input type="date" class="input" value="@_editExpense!.Date.ToString("yyyy-MM-dd")" @onchange="e => _editExpense.Date = DateTime.Parse(e.Value!.ToString()!)" />
                <label>Description</label>
                <input class="input" @bind="_editExpense.Description" />
                <label>Amount</label>
                <input type="number" step="0.01" class="input" @bind="_editExpense.Amount" />
                <label>Comments</label>
                <textarea class="input" @bind="_editExpense.Comments"></textarea>
            }

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseEditor">Cancel</button>
                <button class="btn-primary" @onclick="Save">Save 🌸</button>
            </div>
        </div>
    </div>
}

@code {
    private List<IncomeEntry> _allIncomes = new();
    private List<ExpenseEntry> _allExpenses = new();
    private List<IncomeEntry> _monthIncomes = new();
    private List<ExpenseEntry> _monthExpenses = new();
    private List<DateTime> _availableMonths = new();
    private string _selectedMonth = DateTime.Today.ToString("yyyy-MM");

    private decimal _monthIncomeTotal, _monthExpenseTotal, _grandTotal;

    private bool _showEditor;
    private bool _isIncomeMode;
    private IncomeEntry? _editIncome;
    private ExpenseEntry? _editExpense;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        var userId = CurrentUser.CurrentUserId!.Value;
        _allIncomes = await Db.Incomes.Where(i => i.UserId == userId).ToListAsync();
        _allExpenses = await Db.Expenses.Where(e => e.UserId == userId).ToListAsync();

        var months = _allIncomes.Select(i => new DateTime(i.Date.Year, i.Date.Month, 1))
            .Concat(_allExpenses.Select(e => new DateTime(e.Date.Year, e.Date.Month, 1)))
            .Append(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1))
            .Distinct().OrderByDescending(d => d).ToList();
        _availableMonths = months;

        ApplyMonthFilter();
    }

    private void ApplyMonthFilter()
    {
        var parts = _selectedMonth.Split('-');
        var year = int.Parse(parts[0]);
        var month = int.Parse(parts[1]);

        _monthIncomes = _allIncomes.Where(i => i.Date.Year == year && i.Date.Month == month).OrderByDescending(i => i.Date).ToList();
        _monthExpenses = _allExpenses.Where(e => e.Date.Year == year && e.Date.Month == month).OrderByDescending(e => e.Date).ToList();

        _monthIncomeTotal = _monthIncomes.Sum(i => i.Amount);
        _monthExpenseTotal = _monthExpenses.Sum(e => e.Amount);
        _grandTotal = _monthIncomeTotal - _monthExpenseTotal;
    }

    protected override void OnParametersSet() => ApplyMonthFilter();

    private void OpenEditor(bool isIncome)
    {
        _isIncomeMode = isIncome;
        if (isIncome) _editIncome = new IncomeEntry { UserId = CurrentUser.CurrentUserId!.Value, Date = DateTime.Today };
        else _editExpense = new ExpenseEntry { UserId = CurrentUser.CurrentUserId!.Value, Date = DateTime.Today };
        _showEditor = true;
    }

    private void EditIncome(IncomeEntry i) { _isIncomeMode = true; _editIncome = i; _showEditor = true; }
    private void EditExpense(ExpenseEntry x) { _isIncomeMode = false; _editExpense = x; _showEditor = true; }

    private void CloseEditor()
    {
        _showEditor = false; _editIncome = null; _editExpense = null;
    }

    private async Task Save()
    {
        if (_isIncomeMode)
        {
            if (_editIncome!.Id == 0) Db.Incomes.Add(_editIncome);
            else Db.Incomes.Update(_editIncome);
        }
        else
        {
            if (_editExpense!.Id == 0) Db.Expenses.Add(_editExpense);
            else Db.Expenses.Update(_editExpense);
        }
        await Db.SaveChangesAsync();
        CloseEditor();
        await LoadAll();
    }

    private async Task DeleteIncome(IncomeEntry i) { Db.Incomes.Remove(i); await Db.SaveChangesAsync(); await LoadAll(); }
    private async Task DeleteExpense(ExpenseEntry x) { Db.Expenses.Remove(x); await Db.SaveChangesAsync(); await LoadAll(); }
}
